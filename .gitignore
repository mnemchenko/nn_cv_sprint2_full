# ============================================================
# Стандартные исключения mmsegmentation (форк OSS)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
*.egg-info/
*.egg
build/
dist/
.eggs/
.coverage
htmlcov/
.tox/
.cache/
.mypy_cache/
.ipynb_checkpoints/
.DS_Store

# IDE
.vscode/
.idea/

# ============================================================
# Проектные исключения (Спринт 2 cat/dog)
# ============================================================

# локальное Python-окружение (на ВМ ставим свежее через setup_vm.sh)
practicum_venv/
venv/
.venv/

# результаты обучения mmseg — большие чекпойнты, не место в git
work_dirs/

# исходные данные — переносятся на ВМ через scp, не место в git
data/segmentation_dataset/

# промежуточные CVAT-экспорты — не нужны на ВМ и в git
data/cvat_export_*/

# бэкап оригинальных масок до правок CVAT — для локального отката, не нужно в git
data/labels_backup_*/

# логи запусков (ClearML и mmseg оставляют локальные)
*.log
log/
logs/

# секреты — никогда в git
keys.txt
.env
*.pem
*.key
clearml.conf
user_key
